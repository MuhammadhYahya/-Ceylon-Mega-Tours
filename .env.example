# Public site URL used for canonical metadata, robots, and sitemap generation.
# Set this only for the production deployment, for example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS connection used for tour packages and Studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-07-01
SANITY_API_WRITE_TOKEN=

# Studio access toggle.
# Preview / staging: true
# Production: false
ENABLE_STUDIO=true

# SMTP settings for inquiry form delivery.
# Example:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=info@ceylonmegatours.com
# SMTP_PASS=your-password
# SMTP_FROM=info@ceylonmegatours.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional Cloudflare Turnstile protection for inquiry submissions.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
