# Public site URL used for canonical metadata, robots, and sitemap generation.
NEXT_PUBLIC_SITE_URL=https://www.ceylonmegatours.com

# Sanity CMS connection used for tour packages and Studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-07-01
SANITY_API_WRITE_TOKEN=

# Studio access toggle. Keep false on the public production site.
ENABLE_STUDIO=false

# SMTP settings for inquiry form delivery.
# Example:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=info@ceylonmegatours.com
# SMTP_PASS=your-password
# SMTP_FROM=info@ceylonmegatours.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

